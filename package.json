{
  "name": "intmap",
  "version": "1.0.0",
  "description": "Interactive 3D building map",
  "scripts": {
    "start": "webpack serve --mode development",
    "build": "npm run clean && webpack --mode production && npm run copy-assets",
    "build:dev": "npm run clean && webpack --mode development",
    "clean": "rimraf dist",
    "copy-assets": "copyfiles -u 1 public/**/* dist/"
  },
  "dependencies": {
    "@babylonjs/core": "8.55.1",
    "@babylonjs/gui": "8.55.1",
    "@babylonjs/loaders": "8.55.1",
    "inversify": "^6.0.1",
    "marked": "^12.0.0",
    "qr-scanner": "^1.4.2",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "copy-webpack-plugin": "^12.0.2",
    "copyfiles": "^2.4.1",
    "css-loader": "^6.8.1",
    "prettier": "^3.8.1",
    "rimraf": "^5.0.5",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
